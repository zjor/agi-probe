# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
ALLOWED_TELEGRAM_USERS=123456789,987654321

# Runtime
RUNTIME_DIR=~/.agi-probe/runtime

# Heartbeat interval in milliseconds (default: 60000 = 60s)
HEARTBEAT_INTERVAL_MS=60000

# Cost limit in USD per session (default: 5.0)
COST_LIMIT_USD=5.0

# Max tool call iterations per tick (default: 10)
MAX_TOOL_ITERATIONS=10

# Conversation history sliding window size (default: 20)
CONVERSATION_HISTORY_LENGTH=20

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Tavily web search API (free tier: 1000 queries/month)
TAVILY_API_KEY=tvly-...
